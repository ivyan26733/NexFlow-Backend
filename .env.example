# Copy this file to .env and fill in your values before running docker-compose.prod.yml
# .env is gitignored — never commit it

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PGDATABASE=nexflow
PGUSER=postgres
PGPASSWORD=321Ivyan!

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USERNAME=nexflow
RABBITMQ_PASSWORD=change_me_rabbit_password

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL — no trailing slash
# Add multiple URLs comma-separated, e.g.:
#   https://your-app.vercel.app,https://your-custom-domain.com
CORS_ALLOWED_ORIGINS=https://nex-flow-frontend.vercel.app/
