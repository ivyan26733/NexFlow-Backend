# Copy this to .env and fill in real values before running.
# cp .env.example .env
# .env is gitignored — never commit it.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=nexflow
PGUSER=nexflow
PGPASSWORD=change_me_strong_password
PGSSLMODE=disable

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_STOMP_PORT=61613
RABBITMQ_USERNAME=nexflow
RABBITMQ_PASSWORD=change_me_rabbit_password
RABBITMQ_VHOST=/

# ── Redis (dashboard cache) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Spring Boot ───────────────────────────────────────────────────────────────
PORT=8090
SPRING_PROFILES_ACTIVE=prod

# ── CORS — your Vercel frontend URL (no trailing slash) ───────────────────────
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ── JWT — generate with: openssl rand -hex 32 ─────────────────────────────────
JWT_SECRET=change_me_32_char_minimum_secret_key
JWT_EXPIRY_MS=604800000

# ── Frontend URL (used for OAuth2 redirect after Google login) ────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Google OAuth2 (leave empty to disable) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP / Email (leave SMTP_HOST empty to disable — OTP logs to console) ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
